FROM python:3.12-slim

# Install commonly useful packages for data processing / calculations
RUN pip install --no-cache-dir \
    numpy \
    pandas \
    matplotlib \
    sympy

# Drop to non-root user
RUN useradd -m sandbox
USER sandbox
WORKDIR /home/sandbox

# Default entrypoint: run a Python script passed via stdin
ENTRYPOINT ["python3", "-u", "-"]
